SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database — SQLite by default, set to postgresql://user:pass@host/db for Postgres
DATABASE_URL=sqlite:///db.sqlite3

# Media files root (cover art, avatars)
MEDIA_ROOT=./media

# Go scanner service URL
SCANNER_URL=http://localhost:4040

# Shared secret between Django and Go scanner
SCANNER_SECRET=change-this-scanner-secret

# Server display name
SERVER_NAME=Sonata
